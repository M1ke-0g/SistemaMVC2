@model SistemaMVC2.Models.Cliente

@{
    ViewBag.Title = "Detalles del Cliente";
}

<h2>👁️ Detalles del Cliente</h2>

<div class="container-form">
    <div class="form-group">
        <label><strong>ID:</strong></label>
        <p>@Model.ClienteId</p>
    </div>

    <div class="form-group">
        <label><strong>Nombre:</strong></label>
        <p>@Model.Nombre</p>
    </div>

    <div class="form-group">
        <label><strong>Apellidos:</strong></label>
        <p>@Model.Apellidos</p>
    </div>

    <div class="form-group">
        <label><strong>DNI:</strong></label>
        <p>@Model.DNI</p>
    </div>

    <div class="form-group">
        <label><strong>Dirección:</strong></label>
        <p>@Model.Direccion</p>
    </div>

    <div class="form-group">
        <label><strong>Teléfono:</strong></label>
        <p>@Model.Telefono</p>
    </div>

    <div class="btn-group-custom">
        @Html.ActionLink("✏️ Editar", "Edit", new { id = Model.ClienteId }, new { @class = "btn btn-warning btn-lg" })
        @Html.ActionLink("🔙 Volver a la lista", "Index", null, new { @class = "btn btn-default btn-lg" })
    </div>
</div>
