@model SistemaMVC2.Models.Cliente

@{
    ViewBag.Title = "Editar Cliente";
}

<h2>✏️ Editar Cliente</h2>

<div class="container-form">
    @using (Html.BeginForm("Edit", "Cliente", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        @Html.HiddenFor(m => m.ClienteId)

        <div class="form-group">
            @Html.LabelFor(m => m.Nombre)
            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Apellidos)
            @Html.TextBoxFor(m => m.Apellidos, new { @class = "form-control" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.DNI)
            @Html.TextBoxFor(m => m.DNI, new { @class = "form-control" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Direccion)
            @Html.TextBoxFor(m => m.Direccion, new { @class = "form-control" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Telefono)
            @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control" })
        </div>

        <div class="btn-group-custom">
            <button type="submit" class="btn btn-primary btn-lg">💾 Guardar cambios</button>
            @Html.ActionLink("❌ Cancelar", "Index", null, new { @class = "btn btn-default btn-lg" })
        </div>
    }
</div>
