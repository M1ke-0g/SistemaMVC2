@model List<SistemaMVC2.Models.Cliente>

@{
    ViewBag.Title = "Clientes";
}

<h2>👥 Lista de Clientes</h2>

<p>
    @Html.ActionLink("➕ Crear Nuevo Cliente", "Create", null, new { @class = "btn btn-primary" })
</p>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Apellidos</th>
            <th>DNI</th>
            <th>Dirección</th>
            <th>Teléfono</th>
            <th style="width: 200px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Apellidos</td>
                <td>@item.DNI</td>
                <td>@item.Direccion</td>
                <td>@item.Telefono</td>
                <td>
                    @Html.ActionLink("👁️ Ver", "Details", new { id = item.ClienteId }, new { @class = "btn btn-info btn-sm" })
                    @Html.ActionLink("✏️ Editar", "Edit", new { id = item.ClienteId }, new { @class = "btn btn-warning btn-sm" })
                    @Html.ActionLink("🗑️ Eliminar", "Delete", new { id = item.ClienteId }, new { @class = "btn btn-danger btn-sm" })
                </td>
            </tr>
        }
    </tbody>
</table>
