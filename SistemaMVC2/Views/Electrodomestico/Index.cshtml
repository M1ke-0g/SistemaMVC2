@model List<SistemaMVC2.Models.Electrodomestico>

@{
    ViewBag.Title = "Electrodomésticos";
}

<h2>📱 Lista de Electrodomésticos</h2>

<p>
    @Html.ActionLink("➕ Crear Nuevo Electrodoméstico", "Create", null, new { @class = "btn btn-primary" })
</p>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Tipo</th>
            <th>Modelo</th>
            <th>Precio</th>
            <th style="width: 200px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Tipo</td>
                <td>@item.Modelo</td>
                <td>@item.Precio.ToString("C")</td>
                <td>
                    @Html.ActionLink("👁️ Ver", "Details", new { id = item.ElectrodomesticoId }, new { @class = "btn btn-info btn-sm" })
                    @Html.ActionLink("✏️ Editar", "Edit", new { id = item.ElectrodomesticoId }, new { @class = "btn btn-warning btn-sm" })
                    @Html.ActionLink("🗑️ Eliminar", "Delete", new { id = item.ElectrodomesticoId }, new { @class = "btn btn-danger btn-sm" })
                </td>
            </tr>
        }
    </tbody>
</table>
