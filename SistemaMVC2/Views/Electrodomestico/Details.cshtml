@model SistemaMVC2.Models.Electrodomestico

@{
    ViewBag.Title = "Detalles del Electrodoméstico";
}

<h2>👁️ Detalles del Electrodoméstico</h2>

<div class="container-form">
    <div class="form-group">
        <label><strong>ID:</strong></label>
        <p>@Model.ElectrodomesticoId</p>
    </div>

    <div class="form-group">
        <label><strong>Tipo:</strong></label>
        <p>@Model.Tipo</p>
    </div>

    <div class="form-group">
        <label><strong>Modelo:</strong></label>
        <p>@Model.Modelo</p>
    </div>

    <div class="form-group">
        <label><strong>Precio:</strong></label>
        <p>@Model.Precio.ToString("C")</p>
    </div>

    <div class="btn-group-custom">
        @Html.ActionLink("✏️ Editar", "Edit", new { id = Model.ElectrodomesticoId }, new { @class = "btn btn-warning btn-lg" })
        @Html.ActionLink("🔙 Volver a la lista", "Index", null, new { @class = "btn btn-default btn-lg" })
    </div>
</div>
