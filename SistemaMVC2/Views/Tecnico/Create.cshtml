@model SistemaMVC2.Models.Tecnico

@{
    ViewBag.Title = "Crear Técnico";
}

<h2>➕ Crear Nuevo Técnico</h2>

<div class="container-form">
    @using (Html.BeginForm("Create", "Tecnico", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="form-group">
            @Html.LabelFor(m => m.Nombre)
            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", @placeholder = "Ej: Carlos" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Apellidos)
            @Html.TextBoxFor(m => m.Apellidos, new { @class = "form-control", @placeholder = "Ej: Ruiz Sánchez" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.NIF)
            @Html.TextBoxFor(m => m.NIF, new { @class = "form-control", @placeholder = "Ej: 11223344C" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Movil)
            @Html.TextBoxFor(m => m.Movil, new { @class = "form-control", @placeholder = "Ej: 666-1111" })
        </div>

        <div class="btn-group-custom">
            <button type="submit" class="btn btn-primary btn-lg">💾 Guardar</button>
            @Html.ActionLink("❌ Cancelar", "Index", null, new { @class = "btn btn-default btn-lg" })
        </div>
    }
</div>
