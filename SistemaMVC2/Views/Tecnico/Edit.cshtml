@model SistemaMVC2.Models.Tecnico

@{
    ViewBag.Title = "Editar Técnico";
}

<h2>✏️ Editar Técnico</h2>

<div class="container-form">
    @using (Html.BeginForm("Edit", "Tecnico", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        @Html.HiddenFor(m => m.TecnicoId)

        <div class="form-group">
            @Html.LabelFor(m => m.Nombre)
            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Apellidos)
            @Html.TextBoxFor(m => m.Apellidos, new { @class = "form-control" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.NIF)
            @Html.TextBoxFor(m => m.NIF, new { @class = "form-control" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Movil)
            @Html.TextBoxFor(m => m.Movil, new { @class = "form-control" })
        </div>

        <div class="btn-group-custom">
            <button type="submit" class="btn btn-primary btn-lg">💾 Guardar cambios</button>
            @Html.ActionLink("❌ Cancelar", "Index", null, new { @class = "btn btn-default btn-lg" })
        </div>
    }
</div>
