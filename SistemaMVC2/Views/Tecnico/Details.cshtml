@model SistemaMVC2.Models.Tecnico

@{
    ViewBag.Title = "Detalles del Técnico";
}

<h2>👁️ Detalles del Técnico</h2>

<div class="container-form">
    <div class="form-group">
        <label><strong>ID:</strong></label>
        <p>@Model.TecnicoId</p>
    </div>

    <div class="form-group">
        <label><strong>Nombre:</strong></label>
        <p>@Model.Nombre</p>
    </div>

    <div class="form-group">
        <label><strong>Apellidos:</strong></label>
        <p>@Model.Apellidos</p>
    </div>

    <div class="form-group">
        <label><strong>NIF:</strong></label>
        <p>@Model.NIF</p>
    </div>

    <div class="form-group">
        <label><strong>Móvil:</strong></label>
        <p>@Model.Movil</p>
    </div>

    <div class="btn-group-custom">
        @Html.ActionLink("✏️ Editar", "Edit", new { id = Model.TecnicoId }, new { @class = "btn btn-warning btn-lg" })
        @Html.ActionLink("🔙 Volver a la lista", "Index", null, new { @class = "btn btn-default btn-lg" })
    </div>
</div>
