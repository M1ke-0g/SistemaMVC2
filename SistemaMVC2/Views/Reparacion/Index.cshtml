@model IEnumerable<SistemaMVC2.Models.Reparacion>

@{
    ViewBag.Title = "Reparaciones";
}

<h2>🔨 Lista de Reparaciones</h2>

<p>
    @Html.ActionLink("➕ Crear Nueva Reparación", "Create", null, new { @class = "btn btn-primary" })
</p>
<table class="table table-hover">
    <thead>
        <tr>
            <th>Descripción</th>
            <th>Fecha</th>
            <th>Hora</th>
            <th>Coste</th>
            <th>Garantía</th>
            <th style="width: 200px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Descripcion)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Fecha)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Hora)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Coste)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Garantia)
                </td>
                <td>
                    @Html.ActionLink("👁️ Ver", "Details", new { id=item.Id }, new { @class = "btn btn-info btn-sm" })
                    @Html.ActionLink("✏️ Editar", "Edit", new { id=item.Id }, new { @class = "btn btn-warning btn-sm" })
                    @Html.ActionLink("🗑️ Eliminar", "Delete", new { id=item.Id }, new { @class = "btn btn-danger btn-sm" })
                </td>
            </tr>
        }
    </tbody>
</table>
